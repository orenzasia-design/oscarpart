# ============================================================
# OSCARPART Backend — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# ============================================================

# Application
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
API_PREFIX=/api/v1

# ============================================================
# PostgreSQL Database
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oscarpart
DB_USER=oscarpart_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# ============================================================
# Redis Cache & Session Store
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_TLS=false

# ============================================================
# JWT Authentication
# ============================================================
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_THIS_VERY_LONG_RANDOM_SECRET_ACCESS
JWT_REFRESH_SECRET=CHANGE_THIS_VERY_LONG_RANDOM_SECRET_REFRESH
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ============================================================
# AWS S3 / Cloudflare R2 (File Storage)
# ============================================================
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=ap-southeast-1
S3_BUCKET=oscarpart-files
S3_ACCESS_KEY_ID=YOUR_ACCESS_KEY
S3_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
S3_PUBLIC_URL=https://files.oscarpart.id

# ============================================================
# Email (SendGrid / SMTP)
# ============================================================
EMAIL_PROVIDER=smtp            # smtp | sendgrid
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=YOUR_EMAIL@gmail.com
SMTP_PASSWORD=YOUR_APP_PASSWORD
EMAIL_FROM_NAME=OSCARPART
EMAIL_FROM_ADDRESS=noreply@oscarpart.id
EMAIL_ADMIN=admin@oscarpart.id

# SendGrid (if provider=sendgrid)
SENDGRID_API_KEY=SG.YOUR_KEY_HERE

# ============================================================
# WhatsApp
# ============================================================
WHATSAPP_NUMBER=62XXXXXXXXXX       # No + prefix

# ============================================================
# Security
# ============================================================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000         # 1 minute
RATE_LIMIT_MAX_PUBLIC=30
RATE_LIMIT_MAX_AUTHENTICATED=100
CORS_ORIGIN=http://localhost:3000
COOKIE_SECRET=CHANGE_THIS_COOKIE_SECRET

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=debug                     # error | warn | info | debug
LOG_FILE=logs/app.log
