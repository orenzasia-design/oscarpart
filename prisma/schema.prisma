generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model activity_feed {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  actor_user_id String?  @db.Uuid
  action_type   String   @db.VarChar(50)
  description   String
  metadata      Json?
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  users         users?   @relation(fields: [actor_user_id], references: [id], onUpdate: NoAction)
}

model audit_log {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id     String?  @db.Uuid
  action      String   @db.VarChar(100)
  entity_type String?  @db.VarChar(50)
  entity_id   String?  @db.Uuid
  ip_address  String?  @db.VarChar(45)
  user_agent  String?
  metadata    Json?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  users       users?   @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model brands {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String   @db.VarChar(100)
  slug       String   @unique @db.VarChar(100)
  logo_url   String?
  active     Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  parts      parts[]
}

model leads {
  id                             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  rfq_session_id                 String?       @db.Uuid
  user_id                        String?       @db.Uuid
  company_name                   String?       @db.VarChar(200)
  contact_person                 String?       @db.VarChar(150)
  email                          String?       @db.VarChar(255)
  whatsapp                       String?       @db.VarChar(30)
  project_name                   String?       @db.VarChar(255)
  industry                       String?       @db.VarChar(100)
  lead_source                    lead_source   @default(rfq_manual)
  lead_status                    lead_status   @default(new)
  potential_value                Decimal?      @db.Decimal(15, 2)
  assigned_to                    String?       @db.Uuid
  notes                          String?
  contacted_at                   DateTime?     @db.Timestamptz(6)
  closed_at                      DateTime?     @db.Timestamptz(6)
  created_at                     DateTime      @default(now()) @db.Timestamptz(6)
  updated_at                     DateTime      @default(now()) @db.Timestamptz(6)
  users_leads_assigned_toTousers users?        @relation("leads_assigned_toTousers", fields: [assigned_to], references: [id], onUpdate: NoAction)
  rfq_sessions                   rfq_sessions? @relation(fields: [rfq_session_id], references: [id], onUpdate: NoAction)
  users_leads_user_idTousers     users?        @relation("leads_user_idTousers", fields: [user_id], references: [id], onUpdate: NoAction)
}

model notifications {
  id                 String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type               notification_type
  recipient_user_id  String?             @db.Uuid
  recipient_email    String?             @db.VarChar(255)
  recipient_whatsapp String?             @db.VarChar(30)
  subject            String?             @db.VarChar(500)
  body               String
  status             notification_status @default(pending)
  sent_at            DateTime?           @db.Timestamptz(6)
  error_message      String?
  retry_count        Int                 @default(0)
  created_at         DateTime            @default(now()) @db.Timestamptz(6)
  users              users?              @relation(fields: [recipient_user_id], references: [id], onUpdate: NoAction)
}

model parts {
  id                 String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  part_number        String      @unique @db.VarChar(100)
  description        String?
  unit_type          String?     @db.VarChar(50)
  brand_id           String?     @db.Uuid
  brand_name         String?     @db.VarChar(100)
  stock_quantity     Decimal     @default(0) @db.Decimal(12, 2)
  unit_price         Decimal?    @db.Decimal(15, 2)
  warehouse_id       String?     @db.Uuid
  warehouse_location String?     @db.VarChar(50)
  status             part_status @default(active)
  notes              String?
  created_at         DateTime    @default(now()) @db.Timestamptz(6)
  updated_at         DateTime    @default(now()) @db.Timestamptz(6)
  brands             brands?     @relation(fields: [brand_id], references: [id], onUpdate: NoAction)
  warehouses         warehouses? @relation(fields: [warehouse_id], references: [id], onUpdate: NoAction)
  rfq_items          rfq_items[]
}

model refresh_tokens {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique @db.VarChar(255)
  expires_at DateTime  @db.Timestamptz(6)
  revoked    Boolean   @default(false)
  revoked_at DateTime? @db.Timestamptz(6)
  ip_address String?   @db.VarChar(45)
  user_agent String?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model rfq_items {
  id                 String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  rfq_session_id     String       @db.Uuid
  part_number        String       @db.VarChar(100)
  part_id            String?      @db.Uuid
  description        String?
  brand              String?      @db.VarChar(100)
  unit_type          String?      @db.VarChar(50)
  stock_available    Decimal?     @db.Decimal(12, 2)
  unit_price_at_time Decimal?     @db.Decimal(15, 2)
  qty_requested      Decimal      @default(1) @db.Decimal(12, 2)
  line_total         Decimal?     @db.Decimal(15, 2)
  match_status       match_status @default(unmatched)
  sort_order         Int          @default(0)
  created_at         DateTime     @default(now()) @db.Timestamptz(6)
  parts              parts?       @relation(fields: [part_id], references: [id], onUpdate: NoAction)
  rfq_sessions       rfq_sessions @relation(fields: [rfq_session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model rfq_number_sequences {
  date          DateTime @id @db.Date
  last_sequence Int      @default(0)
}

model rfq_sessions {
  id                String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  rfq_number        String        @unique @db.VarChar(30)
  user_id           String?       @db.Uuid
  session_token     String?       @db.VarChar(255)
  company_name      String?       @db.VarChar(200)
  contact_person    String?       @db.VarChar(150)
  position          String?       @db.VarChar(100)
  email             String?       @db.VarChar(255)
  whatsapp          String?       @db.VarChar(30)
  project_name      String?       @db.VarChar(255)
  delivery_location String?       @db.VarChar(255)
  notes             String?
  status            rfq_status    @default(draft)
  subtotal          Decimal?      @db.Decimal(15, 2)
  tax_rate          Decimal       @default(11.00) @db.Decimal(5, 2)
  tax_amount        Decimal?      @db.Decimal(15, 2)
  grand_total       Decimal?      @db.Decimal(15, 2)
  pdf_path          String?
  pdf_generated_at  DateTime?     @db.Timestamptz(6)
  created_at        DateTime      @default(now()) @db.Timestamptz(6)
  submitted_at      DateTime?     @db.Timestamptz(6)
  updated_at        DateTime      @default(now()) @db.Timestamptz(6)
  leads             leads[]
  rfq_items         rfq_items[]
  users             users?        @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  rfq_uploads       rfq_uploads[]
}

model rfq_uploads {
  id                String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  rfq_session_id    String            @db.Uuid
  original_filename String            @db.VarChar(255)
  s3_key            String?
  file_type         file_type
  file_size_bytes   Int?
  rows_total        Int?
  rows_matched      Int?
  rows_unmatched    Int?
  processing_status processing_status @default(pending)
  error_message     String?
  created_at        DateTime          @default(now()) @db.Timestamptz(6)
  rfq_sessions      rfq_sessions      @relation(fields: [rfq_session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model search_logs {
  id                   String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id              String?  @db.Uuid
  session_id           String?  @db.VarChar(255)
  part_number_searched String   @db.VarChar(100)
  found                Boolean  @default(false)
  result_count         Int      @default(0)
  ip_address           String?  @db.VarChar(45)
  user_agent           String?
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  users                users?   @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model settings {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  key         String   @unique @db.VarChar(100)
  value       String?
  value_type  String   @default("string") @db.VarChar(20)
  description String?
  updated_by  String?  @db.Uuid
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  users       users?   @relation(fields: [updated_by], references: [id], onUpdate: NoAction)
}

model users {
  id                             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email                          String           @unique @db.VarChar(255)
  password_hash                  String           @db.VarChar(255)
  full_name                      String           @db.VarChar(150)
  role                           user_role        @default(registered)
  status                         user_status      @default(pending)
  company_name                   String?          @db.VarChar(200)
  business_type                  String?          @db.VarChar(100)
  contact_person                 String?          @db.VarChar(150)
  position                       String?          @db.VarChar(100)
  mobile_number                  String?          @db.VarChar(30)
  whatsapp_number                String?          @db.VarChar(30)
  project_location               String?          @db.VarChar(255)
  industry                       String?          @db.VarChar(100)
  website                        String?          @db.VarChar(255)
  approved_by                    String?          @db.Uuid
  approved_at                    DateTime?        @db.Timestamptz(6)
  rejection_reason               String?
  created_at                     DateTime         @default(now()) @db.Timestamptz(6)
  updated_at                     DateTime         @default(now()) @db.Timestamptz(6)
  last_login_at                  DateTime?        @db.Timestamptz(6)
  activity_feed                  activity_feed[]
  audit_log                      audit_log[]
  leads_leads_assigned_toTousers leads[]          @relation("leads_assigned_toTousers")
  leads_leads_user_idTousers     leads[]          @relation("leads_user_idTousers")
  notifications                  notifications[]
  refresh_tokens                 refresh_tokens[]
  rfq_sessions                   rfq_sessions[]
  search_logs                    search_logs[]
  settings                       settings[]
  users                          users?           @relation("usersTousers", fields: [approved_by], references: [id], onUpdate: NoAction)
  other_users                    users[]          @relation("usersTousers")
}

model warehouses {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String   @db.VarChar(100)
  location   String?  @db.VarChar(255)
  code       String   @unique @db.VarChar(20)
  active     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  parts      parts[]
}

enum file_type {
  xlsx
  xls
  csv
}

enum lead_source {
  search
  rfq_manual @map("rfq-manual")
  rfq_upload @map("rfq-upload")
  direct
}

enum lead_status {
  new
  contacted
  qualified
  won
  lost
}

enum match_status {
  matched
  unmatched
  partial
}

enum notification_status {
  pending
  sent
  failed
}

enum notification_type {
  email
  whatsapp
  system
}

enum part_status {
  active
  inactive
  discontinued
}

enum processing_status {
  pending
  processing
  completed
  failed
}

enum rfq_status {
  draft
  submitted
  processing
  quoted
  closed
  cancelled
}

enum user_role {
  public
  registered
  approved
  admin
  superadmin
}

enum user_status {
  pending
  approved
  rejected
  suspended
}
